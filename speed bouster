--// LOGIQUE FLOCONS
local function spawnFlake()
    local flake = Instance.new("TextLabel")
    flake.BackgroundTransparency = 1
    flake.Text = "❄"
    flake.TextColor3 = Color3.new(1, 1, 1)
    flake.TextScaled = true
    flake.ZIndex = 1
    local size = math.random(15, 25)
    flake.Size = UDim2.new(0, size, 0, size)
    flake.Position = UDim2.new(math.random(), 0, -0.1, 0)
    flake.Parent = main

    local info = TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Linear)
    local tween = TweenService:Create(flake, info, {Position = UDim2.new(flake.Position.X.Scale, 0, 1, 0)})
    tween:Play()
    tween.Completed:Connect(function() flake:Destroy() end)
end

task.spawn(function()
    while true do
        if main.Visible then spawnFlake() end
        task.wait(0.5)
    end
end)

