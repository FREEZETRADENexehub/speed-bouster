--// INPUTS
local function createInput(name, y, default)
    local lab = Instance.new("TextLabel")
    lab.Size = UDim2.new(0.4, 0, 0, 30)
    lab.Position = UDim2.new(0.1, 0, 0, y)
    lab.Text = name
    lab.TextColor3 = Color3.fromRGB(180, 180, 180)
    lab.BackgroundTransparency = 1
    lab.TextXAlignment = "Left"
    lab.ZIndex = 10
    lab.Parent = main

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.35, 0, 0, 30)
    box.Position = UDim2.new(0.55, 0, 0, y)
    box.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    box.Text = tostring(default)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.ZIndex = 10
    box.Parent = main
    Instance.new("UICorner", box)
    return box
end

local vInput = createInput("Vitesse", 120, 53)
local sInput = createInput("Voler", 180, 29)
local jInput = createInput("Saut", 240, 400)

--// LOGIQUE DE TRICHE
activateBtn.MouseButton1Click:Connect(function()
    active = not active
    activateBtn.Text = active and "ACTIVÉ" or "DÉSACTIVÉ"
    activateBtn.BackgroundColor3 = active and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(35, 35, 35)
    
    if active then
        loop = RunService.Heartbeat:Connect(function()
            local char = lp.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hum = char:FindFirstChild("Humanoid")
                local root = char.HumanoidRootPart
                if hum and hum.MoveDirection.Magnitude > 0 then
                    local speed = (hum.WalkSpeed < 25) and tonumber(sInput.Text) or tonumber(vInput.Text)
                    root.AssemblyLinearVelocity = Vector3.new(hum.MoveDirection.X * speed, root.AssemblyLinearVelocity.Y, hum.MoveDirection.Z * speed)
                end
            end
        end)
    else
        if loop then loop:Disconnect() end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if active and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local root = lp.Character.HumanoidRootPart
        root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X, tonumber(jInput.Text) or 400, root.AssemblyLinearVelocity.Z)
    end
end)

